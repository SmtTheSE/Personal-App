VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side (Vercel env + local vercel dev)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Telegram quick capture
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_WEBHOOK_SECRET=generate-with-openssl-rand-hex-24
TELEGRAM_BOT_USERNAME=your_bot_username_without_at

# Google OAuth (Calendar + Gmail capture)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_STATE_SECRET=generate-with-openssl-rand-hex-32
# Optional overrides
# GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/google/calendar/callback
# GMAIL_REDIRECT_URI=https://your-app.vercel.app/api/gmail/callback

# Web push (optional — enables push when Telegram disconnected)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
